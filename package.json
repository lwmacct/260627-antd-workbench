{
  "name": "@lwmacct/260627-antd-workbench",
  "version": "0.46.260709",
  "private": false,
  "packageManager": "pnpm@11.10.0",
  "description": "Opinionated React and Ant Design workbench shell, layout, and theme primitives.",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "build:example": "vite build --config vite.example.config.ts",
    "dev": "vite --config vite.example.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.example.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "npm": "please-use-pnpm"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./global.css": "./dist/global.css",
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "import": "./dist/security.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "./dist/global.css",
    "./dist/styles.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lwmacct/260627-antd-workbench.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@ant-design/icons": "^6.0.0",
    "antd": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "antd": "^6.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
